{{!
    @template theme_moove/footer

    GT4T Footer matching gt4t.intelligent-industry.fi design.

    Example context (json):
    {
        "output": {
            "page_doc_link": "Help and documentation",
            "supportemail": "<a href=\"#\">Contact site support</a>",
            "has_popover_links": true,
            "services_support": "Services and support",
            "login_info": "You are logged in as cute kitten",
            "moodle_release": "90210"
        },
        "gt4t_footer": {
            "description": "A Europe-wide initiative...",
            "disclaimer": "GT4T is supported by...",
            "copyright": "Green Tech for Transformation 2026"
        }
    }
}}

<footer id="page-footer" class="footer-popover gt4t-footer">
    <div class="gt4t-footer__main">
        <div class="gt4t-footer__container">
            <div class="gt4t-footer__grid">
                <div class="gt4t-footer__left">
                    {{# output.should_display_logo }}
                        <div class="gt4t-footer__logo">
                            <img src="{{output.get_logo}}" class="logo light" alt="{{sitename}}">
                            {{#output.get_logo_dark}}
                                <img src="{{.}}" class="logo dark" alt="{{sitename}}">
                            {{/output.get_logo_dark}}
                        </div>
                    {{/ output.should_display_logo }}
                    {{^ output.should_display_logo }}
                        <div class="gt4t-footer__logo">
                            <span class="gt4t-footer__sitename">{{{ sitename }}}</span>
                        </div>
                    {{/ output.should_display_logo }}

                    {{#gt4t_footer}}
                        <p class="gt4t-footer__description">{{{description}}}</p>
                    {{/gt4t_footer}}

                    {{#hasfootersocial}}
                        <div class="gt4t-footer__social">
                            {{#linkedin}}
                                <a href="{{{linkedin}}}" target="_blank" class="gt4t-footer__social-link" aria-label="LinkedIn">
                                    <i class="fa fa-linkedin"></i>
                                </a>
                            {{/linkedin}}
                            {{#mail}}
                                <a href="mailto:{{{mail}}}" class="gt4t-footer__social-link" aria-label="Email">
                                    <i class="fa fa-envelope"></i>
                                </a>
                            {{/mail}}
                            {{#facebook}}
                                <a href="{{{facebook}}}" target="_blank" class="gt4t-footer__social-link" aria-label="Facebook">
                                    <i class="fa fa-facebook"></i>
                                </a>
                            {{/facebook}}
                            {{#twitter}}
                                <a href="{{{twitter}}}" target="_blank" class="gt4t-footer__social-link" aria-label="Twitter">
                                    <i class="fa fa-twitter"></i>
                                </a>
                            {{/twitter}}
                            {{#instagram}}
                                <a href="{{{instagram}}}" target="_blank" class="gt4t-footer__social-link" aria-label="Instagram">
                                    <i class="fa fa-instagram"></i>
                                </a>
                            {{/instagram}}
                            {{#youtube}}
                                <a href="{{{youtube}}}" target="_blank" class="gt4t-footer__social-link" aria-label="YouTube">
                                    <i class="fa fa-youtube"></i>
                                </a>
                            {{/youtube}}
                        </div>
                    {{/hasfootersocial}}

                    {{#gt4t_footer}}
                        <p class="gt4t-footer__copyright">{{{copyright}}}</p>
                    {{/gt4t_footer}}
                </div>

                <div class="gt4t-footer__right">
                    {{#gt4t_footer}}
                        <p class="gt4t-footer__disclaimer">{{{disclaimer}}}</p>
                        <div class="gt4t-footer__partner-logos">
                            <img src="{{{wwwroot}}}/theme/moove/pix/gt4t_climate_kic.svg" alt="Climate KIC" class="gt4t-footer__partner-logo">
                            <img src="{{{wwwroot}}}/theme/moove/pix/gt4t_eu_flag.svg" alt="Funded by the European Union" class="gt4t-footer__partner-logo">
                            <img src="{{{wwwroot}}}/theme/moove/pix/gt4t_eit_hei.svg" alt="EIT Higher Education Initiative" class="gt4t-footer__partner-logo">
                        </div>
                    {{/gt4t_footer}}

                    <div class="gt4t-footer__moodle-info">
                        {{# output.supportemail }}
                            <div class="supportemail">{{{ output.supportemail }}}</div>
                        {{/ output.supportemail }}
                        {{{ output.login_info }}}
                        {{{ output.standard_footer_html }}}
                        <div class="tool_usertours-resettourcontainer"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="footer-content-debugging footer-dark bg-dark text-light">
        <div class="moove-container-fluid footer-dark-inner">
            {{{ output.debug_footer_html }}}
        </div>
    </div>

    <div data-region="footer-container-popover">
        {{#output.has_communication_links}}
            <button onclick="window.open('{{output.communication_url}}', '_blank', 'noreferrer')" class="btn btn-icon rounded-circle bg-primary text-white btn-footer-communication" aria-label="{{#str}}communicationroomlink, course{{/str}}">
                {{#pix}}t/messages-o, core{{/pix}}
            </button>
        {{/output.has_communication_links}}
        <button class="btn btn-icon rounded-circle bg-secondary btn-footer-popover" data-action="footer-popover" aria-label="{{#str}}showfooter, theme_boost{{/str}}">
            {{#pix}}e/question, core{{/pix}}
        </button>
    </div>
    <div class="footer-content-popover container" data-region="footer-content-popover">
        {{# output.has_popover_links }}
            <div class="footer-section p-3 border-bottom">
                {{# output.page_doc_link }}
                    <div>{{{ output.page_doc_link }}}</div>
                {{/ output.page_doc_link }}

                {{# output.services_support_link }}
                    <div>{{{ output.services_support_link }}}</div>
                {{/ output.services_support_link }}
            </div>
        {{/ output.has_popover_links }}
        <div class="footer-section p-3">
            <div>{{#str}}poweredbymoodle, core{{/str}}</div>
            {{#output.moodle_release}}
                <div>
                    {{#str}}version, core{{/str}} {{{ output.moodle_release }}}
                </div>
            {{/output.moodle_release}}
        </div>
    </div>
</footer>

{{{ output.standard_end_of_body_html }}}

{{#js}}
    require(['theme_boost/footer-popover'], function(FooterPopover) {
    FooterPopover.init();
    });
{{/js}}